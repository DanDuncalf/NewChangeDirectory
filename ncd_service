#!/bin/bash
#
# ncd_service  --  NCD State Service launcher for Linux
#

# Get directory where this script is located
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SERVICE_NAME="ncd-state-service"
SERVICE_EXE="$SCRIPT_DIR/NCDService"
PID_FILE="${XDG_RUNTIME_DIR:-/tmp}/ncd_service.pid"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

print_usage() {
    echo "NCD State Service Launcher"
    echo ""
    echo "Usage: ncd_service [command]"
    echo ""
    echo "Commands:"
    echo "  start    - Start the NCD State Service"
    echo "  stop     - Stop the NCD State Service"
    echo "  restart  - Restart the NCD State Service"
    echo "  status   - Check if service is running"
    echo "  help     - Show this help message"
    echo ""
}

check_running() {
    if [ -f "$PID_FILE" ]; then
        local pid=$(cat "$PID_FILE" 2>/dev/null)
        if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
            return 0
        fi
    fi
    return 1
}

do_start() {
    if check_running; then
        echo -e "${YELLOW}NCD State Service is already running${NC}"
        return 1
    fi

    if [ ! -f "$SERVICE_EXE" ]; then
        echo -e "${RED}ERROR: $SERVICE_EXE not found${NC}"
        return 1
    fi

    echo "Starting NCD State Service..."
    nohup "$SERVICE_EXE" > "${XDG_RUNTIME_DIR:-/tmp}/ncd_service.log" 2>&1 &
    local pid=$!
    echo $pid > "$PID_FILE"
    sleep 1
    if kill -0 $pid 2>/dev/null; then
        echo -e "${GREEN}NCD State Service started successfully (PID: $pid)${NC}"
        return 0
    else
        echo -e "${RED}ERROR: Failed to start NCD State Service${NC}"
        rm -f "$PID_FILE"
        return 1
    fi
}

do_stop() {
    if ! check_running; then
        echo -e "${YELLOW}Not running${NC}"
        return 1
    fi

    echo "Stopping NCD State Service..."
    local pid=$(cat "$PID_FILE" 2>/dev/null)
    if [ -n "$pid" ]; then
        kill "$pid" 2>/dev/null
        local count=0
        while kill -0 "$pid" 2>/dev/null && [ $count -lt 5 ]; do
            sleep 1
            count=$((count + 1))
        done
        if kill -0 "$pid" 2>/dev/null; then
            kill -9 "$pid" 2>/dev/null
        fi
    fi
    rm -f "$PID_FILE"
    echo -e "${GREEN}NCD State Service stopped${NC}"
}

do_status() {
    if check_running; then
        local pid=$(cat "$PID_FILE" 2>/dev/null)
        echo -e "${GREEN}NCD State Service is running (PID: $pid)${NC}"
    else
        echo -e "${YELLOW}NCD State Service is stopped${NC}"
    fi
}

do_restart() {
    do_stop
    local stop_rc=$?
    sleep 1
    do_start
    local start_rc=$?
    return $start_rc
}

command="${1:-status}"
rc=0
case "$command" in
    start)
        do_start
        rc=$?
        ;;
    stop)
        do_stop
        rc=$?
        ;;
    restart)
        do_restart
        rc=$?
        ;;
    status)
        do_status
        rc=$?
        ;;
    help|--help|-h)
        print_usage
        ;;
    *)
        echo -e "${RED}Unknown command: $command${NC}"
        print_usage
        exit 1
        ;;
esac

exit $rc
