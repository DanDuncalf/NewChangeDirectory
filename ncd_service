#!/bin/bash
#
# ncd_service  --  NCD State Service launcher for Linux
#
# Usage:
#   ncd_service start    - Start the service
#   ncd_service stop     - Stop the service
#   ncd_service status   - Check if service is running
#   ncd_service restart  - Restart the service
#

SERVICE_NAME="ncd-state-service"
SERVICE_EXE="./NCDService"
PID_FILE="${XDG_RUNTIME_DIR:-/tmp}/ncd_service.pid"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Functions
print_usage() {
    echo "NCD State Service Launcher"
    echo ""
    echo "Usage: ncd_service [command]"
    echo ""
    echo "Commands:"
    echo "  start    - Start the NCD State Service"
    echo "  stop     - Stop the NCD State Service"
    echo "  restart  - Restart the NCD State Service"
    echo "  status   - Check if service is running"
    echo "  help     - Show this help message"
    echo ""
    echo "The NCD State Service keeps directory databases hot in memory"
    echo "for faster navigation. It is optional - NCD works without it."
    echo ""
}

check_running() {
    if [ -f "$PID_FILE" ]; then
        local pid=$(cat "$PID_FILE" 2>/dev/null)
        if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
            return 0  # Running
        fi
    fi
    return 1  # Not running
}

do_start() {
    if check_running; then
        echo -e "${YELLOW}NCD State Service is already running${NC}"
        return 0
    fi

    if [ ! -f "$SERVICE_EXE" ]; then
        echo -e "${RED}ERROR: $SERVICE_EXE not found${NC}"
        echo "Please build the project first with build.sh"
        return 1
    fi

    echo "Starting NCD State Service..."
    
    # Start service in background, redirect output to log
    nohup "$SERVICE_EXE" > "${XDG_RUNTIME_DIR:-/tmp}/ncd_service.log" 2>&1 &
    local pid=$!
    
    # Save PID
    echo $pid > "$PID_FILE"
    
    # Wait a moment and check if still running
    sleep 1
    if kill -0 $pid 2>/dev/null; then
        echo -e "${GREEN}NCD State Service started successfully (PID: $pid)${NC}"
        return 0
    else
        echo -e "${RED}ERROR: Failed to start NCD State Service${NC}"
        rm -f "$PID_FILE"
        return 1
    fi
}

do_stop() {
    if ! check_running; then
        echo -e "${YELLOW}NCD State Service is not running${NC}"
        return 0
    fi

    echo "Stopping NCD State Service..."
    
    local pid=$(cat "$PID_FILE" 2>/dev/null)
    if [ -n "$pid" ]; then
        kill "$pid" 2>/dev/null
        
        # Wait for process to terminate
        local count=0
        while kill -0 "$pid" 2>/dev/null && [ $count -lt 5 ]; do
            sleep 1
            count=$((count + 1))
        done
        
        # Force kill if still running
        if kill -0 "$pid" 2>/dev/null; then
            kill -9 "$pid" 2>/dev/null
        fi
    fi
    
    rm -f "$PID_FILE"
    echo -e "${GREEN}NCD State Service stopped${NC}"
}

do_status() {
    if check_running; then
        local pid=$(cat "$PID_FILE" 2>/dev/null)
        echo -e "${GREEN}NCD State Service is running (PID: $pid)${NC}"
        
        # Show some basic stats
        if [ -f "/proc/$pid/status" ]; then
            echo ""
            grep -E "^(VmRSS|VmSize)" "/proc/$pid/status" 2>/dev/null | sed 's/^/  /'
        fi
    else
        echo -e "${YELLOW}NCD State Service is not running${NC}"
    fi
}

do_restart() {
    do_stop
    sleep 1
    do_start
}

# Main
command="${1:-status}"

case "$command" in
    start)
        do_start
        ;;
    stop)
        do_stop
        ;;
    restart)
        do_restart
        ;;
    status)
        do_status
        ;;
    help|--help|-h)
        print_usage
        ;;
    *)
        echo -e "${RED}Unknown command: $command${NC}"
        print_usage
        exit 1
        ;;
esac

exit 0
